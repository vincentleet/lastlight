# Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used to build the Discord OAuth redirect URL when the `origin`/`host` request
# headers aren't reliable (e.g. behind some proxies). Optional locally.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Project Settings -> Database
# Pooled connection (Supavisor, port 6543) - used at runtime by the app.
DATABASE_URL=
# Direct connection (port 5432) - used by drizzle-kit for migrations only.
DIRECT_URL=

# Supabase Authentication -> Providers -> Discord (enable + fill in a Discord OAuth app's
# client ID/secret there, not here). This app only needs to know which Discord user IDs
# are allowed into the admin panel once they've signed in.
# Comma-separated Discord user IDs, e.g. "123456789012345678,987654321098765432"
ADMIN_DISCORD_IDS=

# Stream Deck / Bitfocus Companion webhook auth (static bearer token, internal use only).
# Generate with: openssl rand -hex 32
STREAM_DECK_WEBHOOK_TOKEN=

# Secret used to sign player session cookies (Habbo motto verification + Discord fallback
# both mint the same kind of session once a player is verified).
# Generate with: openssl rand -hex 32
PLAYER_SESSION_SECRET=

# Habbo Origins public API base URL, used to poll a player's motto during verification.
# Confirm the exact path against Habbo Origins' current public API before relying on this —
# unlike the rest of this file, this one is a best guess, not a verified value.
HABBO_API_BASE_URL=https://origins.habbo.com/api/public
